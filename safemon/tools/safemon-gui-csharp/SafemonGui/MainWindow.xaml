<Window x:Class="SafemonGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SafemonGui.ViewModels"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Safemon"
        Height="700"
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border Background="{StaticResource BgMainBrush}"
            BorderBrush="{StaticResource BorderBrush1}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ===================== TOP BAR ===================== -->
            <Grid Grid.Row="0"
                  Background="{StaticResource BgDarkBrush}"
                  MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource SidebarToggleButtonStyle}"
                        Content="&#9776;"
                        Command="{Binding ToggleSidebarCommand}"/>

                <!-- Page title strip -->
                <Border Grid.Column="1"
                        Background="{StaticResource BgTitleStripBrush}"
                        Height="40"
                        VerticalAlignment="Bottom">
                    <Grid>
                        <TextBlock Text="{Binding PageTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                            <TextBlock Text="Target:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <ComboBox Style="{StaticResource DarkComboBoxStyle}"
                                      Width="150"
                                      Height="28"
                                      ItemsSource="{Binding Targets}"
                                      SelectedItem="{Binding CurrentTarget}"
                                      Margin="0,0,10,0"/>

                            <TextBlock Text="User:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Width="80"
                                     Height="26"
                                     Text="{Binding CurrentUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,10,0"/>

                            <TextBlock Text="Pass:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource DarkPasswordBoxStyle}"
                                         Width="80"
                                         Height="26"
                                         PasswordChanged="PasswordInput_PasswordChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource WindowControlButtonStyle}"
                            Content="&#8212;"
                            Click="Minimize_Click"/>
                    <Button Style="{StaticResource WindowControlButtonStyle}"
                            Content="&#9633;"
                            Click="MaximizeRestore_Click"/>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Content="&#10005;"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===================== CONTENT AREA ===================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <!-- Sidebar -->
                <Border x:Name="SidebarBorder"
                        Grid.Column="0"
                        Background="{StaticResource BgDarkBrush}"
                        Width="70"
                        ClipToBounds="True">
                    <StackPanel>
                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                     IsChecked="True"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="0">
                            <StackPanel Orientation="Horizontal">
                                <svgc:SvgViewbox Source="/Assets/Icons/key.svg"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,12,0"/>
                                <TextBlock Text="Key Management"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="1">
                            <StackPanel Orientation="Horizontal">
                                <svgc:SvgViewbox Source="/Assets/Icons/seal_check.svg"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,12,0"/>
                                <TextBlock Text="Sign / Verify"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="2">
                            <StackPanel Orientation="Horizontal">
                                <svgc:SvgViewbox Source="/Assets/Icons/pulse.svg"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,12,0"/>
                                <TextBlock Text="Fault Monitor"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="3">
                            <StackPanel Orientation="Horizontal">
                                <svgc:SvgViewbox Source="/Assets/Icons/folder_open.svg"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,12,0"/>
                                <TextBlock Text="Device Files"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="4">
                            <StackPanel Orientation="Horizontal">
                                <svgc:SvgViewbox Source="/Assets/Icons/monitor.svg"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,12,0"/>
                                <TextBlock Text="Device Status"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="5">
                            <StackPanel Orientation="Horizontal">
                                <svgc:SvgViewbox Source="/Assets/Icons/settings.svg"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,12,0"/>
                                <TextBlock Text="Settings"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Page host -->
                <Border Grid.Column="1"
                        Background="{StaticResource BgMainBrush}">
                    <ContentControl Content="{Binding CurrentPageViewModel}"/>
                </Border>
            </Grid>

            <!-- ===================== STATUS BAR ===================== -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgDarkBrush}">
                <TextBlock Text="Safemon GUI"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Border>
        </Grid>
    </Border>
</Window>