<UserControl x:Class="SafemonGui.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SafemonGui.ViewModels">

    <UserControl.Resources>
        <DataTemplate x:Key="PlatformSectionTemplate" DataType="{x:Type vm:PlatformConfigSectionViewModel}">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="Host:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30"
                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Port:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="User:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30"
                         Text="{Binding User, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource AccentButtonStyle}" Content="Save"
                            Width="80" Height="30" Margin="0,0,8,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Reset"
                            Width="80" Height="30"
                            Command="{Binding ResetCommand}"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Platform config panels -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <ContentPresenter Content="{Binding RaspberryPi}"
                                   ContentTemplate="{StaticResource PlatformSectionTemplate}"/>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <ContentPresenter Content="{Binding JetsonOrinNano}"
                                   ContentTemplate="{StaticResource PlatformSectionTemplate}"/>
            </Border>

            <Border Grid.Column="4" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <ContentPresenter Content="{Binding Qemu}"
                                   ContentTemplate="{StaticResource PlatformSectionTemplate}"/>
            </Border>
        </Grid>

        <!-- App settings panel -->
        <Border Grid.Row="1" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="App Settings" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Journal Lines:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding JournalLines, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Refresh Seconds:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding JournalRefreshSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Key Directory:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding KeyDir, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Button Grid.Column="6" Style="{StaticResource SecondaryButtonStyle}" Content="Browse"
                            Width="80" Height="30" VerticalAlignment="Bottom"
                            Command="{Binding BrowseKeyDirCommand}"/>

                    <Button Grid.Column="8" Style="{StaticResource AccentButtonStyle}" Content="Save"
                            Width="80" Height="30" VerticalAlignment="Bottom"
                            Command="{Binding SaveAppSettingsCommand}"/>

                    <Button Grid.Column="10" Style="{StaticResource SecondaryButtonStyle}" Content="Reset"
                            Width="80" Height="30" VerticalAlignment="Bottom"
                            Command="{Binding ResetAppSettingsCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Save results log -->
        <Border Grid.Row="2" Background="#1A1D23" CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding SaveResultLog}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>