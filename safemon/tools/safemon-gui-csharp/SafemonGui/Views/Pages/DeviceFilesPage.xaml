<UserControl x:Class="SafemonGui.Views.Pages.DeviceFilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Known Files -->
            <Border Grid.Column="0" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="Known Files" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ComboBox Style="{StaticResource DarkComboBoxStyle}" Height="30"
                              ItemsSource="{Binding KnownFiles}"
                              SelectedItem="{Binding SelectedKnownFile}"
                              DisplayMemberPath="FriendlyName"
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Device path: " Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedKnownFile.DevicePath}" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Local: " Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding KnownFileLocalPath}" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Browse Local"
                                Width="100" Height="30" Margin="0,0,8,0"
                                Command="{Binding BrowseKnownFileLocalCommand}"/>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Load from Device"
                                Width="120" Height="30" Margin="0,0,8,0"
                                Command="{Binding LoadFromDeviceCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Style="{StaticResource AccentButtonStyle}" Content="Copy to Device"
                                Width="110" Height="30"
                                Command="{Binding CopyKnownFileToDeviceCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- File Transfer -->
            <Border Grid.Column="2" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="File Transfer" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Local: " Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding TransferLocalPath}" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    </StackPanel>

                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Browse Local File"
                            HorizontalAlignment="Stretch" Height="30" Margin="0,0,0,10"
                            Command="{Binding BrowseTransferLocalCommand}"/>

                    <TextBox Style="{StaticResource DarkTextBoxStyle}" Height="30" Margin="0,0,0,10"
                             Text="{Binding TransferDestinationPath, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Destination on device (e.g. /home/root/)"/>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Copy to Device"
                            HorizontalAlignment="Stretch" Height="30"
                            Command="{Binding CopyTransferToDeviceCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- File preview -->
        <Border Grid.Row="1" Background="#1A1D23" CornerRadius="4" Padding="12" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding FilePreview}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Status log -->
        <Border Grid.Row="2" Background="#1A1D23" CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding StatusLog}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>