<UserControl x:Class="SafemonGui.Views.Pages.SignVerifyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sign File panel -->
            <Border Grid.Column="0" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="Sign File" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding FileToSignPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                Content="Browse" Width="80" Height="30"
                                Command="{Binding BrowseFileToSignCommand}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                Content="Browse" Width="80" Height="30"
                                Command="{Binding BrowsePrivateKeyCommand}"/>
                    </Grid>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Sign"
                            Width="90" Height="30" HorizontalAlignment="Left"
                            Command="{Binding SignCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Verify File panel -->
            <Border Grid.Column="2" Background="{StaticResource BgTitleStripBrush}" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="Verify File" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding FileToVerifyPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                Content="Browse" Width="80" Height="30"
                                Command="{Binding BrowseFileToVerifyCommand}"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding SignaturePath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                Content="Browse" Width="80" Height="30"
                                Command="{Binding BrowseSignatureCommand}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBoxStyle}" Height="30"
                                 Text="{Binding PublicKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                Content="Browse" Width="80" Height="30"
                                Command="{Binding BrowsePublicKeyCommand}"/>
                    </Grid>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Verify"
                            Width="90" Height="30" HorizontalAlignment="Left"
                            Command="{Binding VerifyCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Results log -->
        <Border Grid.Row="1" Background="#1A1D23" CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding ResultLog}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>