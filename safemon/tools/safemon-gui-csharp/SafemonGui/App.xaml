<Application x:Class="SafemonGui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SafemonGui.ViewModels"
             xmlns:views="clr-namespace:SafemonGui.Views.Pages"
             xmlns:converters="clr-namespace:SafemonGui.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:SidebarWidthConverter x:Key="SidebarWidthConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:ServiceStatusToBrushConverter x:Key="ServiceStatusToBrushConverter"/>
            <converters:AutoRefreshLabelConverter x:Key="AutoRefreshLabelConverter"/>
            <converters:ConnectionStatusConverter x:Key="ConnectionStatusConverter"/>
            <converters:ConnectionStatusBrushConverter x:Key="ConnectionStatusBrushConverter"/>
            <converters:FaultStatusToBrushConverter x:Key="FaultStatusToBrushConverter"/>
            <DataTemplate DataType="{x:Type vm:KeyManagementViewModel}">
                <views:KeyManagementPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SignVerifyViewModel}">
                <views:SignVerifyPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DeviceStatusViewModel}">
                <views:DeviceStatusPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DeviceFilesViewModel}">
                <views:DeviceFilesPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FaultMonitorViewModel}">
                <views:FaultMonitorPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>